Option 3: Python SPI Slave (Simpler)
Here's a Python script for testing:

spi_slave.py
#!/usr/bin/env python3
import spidev
import time
import signal
import sys
import threading

# Global flag for running
running = True

def signal_handler(sig, frame):
    global running
    print('\nStopping SPI slave...')
    running = False

class SPISlave:
    def __init__(self, bus=1, device=0):
        self.bus = bus
        self.device = device
        self.spi = None
        
    def init_slave(self):
        """Initialize SPI in slave mode"""
        try:
            self.spi = spidev.SpiDev()
            self.spi.open(self.bus, self.device)
            
            # Configure for slave mode (these are just defaults)
            self.spi.mode = 0b00  # SPI mode 0
            self.spi.bits_per_word = 8
            self.spi.lsbfirst = False
            
            print(f"SPI slave initialized on bus {self.bus}, device {self.device}")
            print(f"Mode: {self.spi.mode}, Bits: {self.spi.bits_per_word}")
            return True
            
        except Exception as e:
            print(f"Failed to initialize SPI: {e}")
            return False
    
    def listen_loop(self):
        """Main listening loop"""
        counter = 0
        
        while running:
            try:
                # Prepare response data
                response = f"Resp{counter:04d}".encode()
                # Pad to make it 32 bytes
                response = response.ljust(32, b'\x00')
                
                # Perform transfer (will block until master communicates)
                # In Python's spidev, this always acts as master
                # For real slave mode, you'd need to use ioctl directly
                # This is a simplified example
                
                # For demonstration, just show that we're waiting
                print(f"Waiting for master... (counter: {counter})", end='\r')
                
                # Simulate slave response delay
                time.sleep(0.1)
                counter += 1
                
            except Exception as e:
                print(f"Error in transfer: {e}")
                break
    
    def cleanup(self):
        """Clean up resources"""
        if self.spi:
            self.spi.close()

def main():
    # Setup signal handling
    signal.signal(signal.SIGINT, signal_handler)
    signal.signal(signal.SIGTERM, signal_handler)
    
    print("NanoPi M4 SPI Slave (Python)")
    print("=============================")
    
    # Create and initialize SPI slave
    slave = SPISlave(bus=1, device=0)
    if not slave.init_slave():
        sys.exit(1)
    
    try:
        print("SPI slave ready. Waiting for master...")
        print("Press Ctrl+C to exit")
        slave.listen_loop()
        
    except Exception as e:
        print(f"Error: {e}")
        
    finally:
        slave.cleanup()
        print("SPI slave stopped")

if __name__ == "__main__":
    main()



Hardware Connections
Connect the NanoPi M4 to STM32F103Z:
NanoPi M4 (Slave)    STM32F103Z (Master)
--------------       ---------------
SPI1_MOSI (Pin)  <->  SPI_MOSI
SPI1_MISO (Pin)  <->  SPI_MISO
SPI1_CLK (Pin)   <->  SPI_SCK
SPI1_CS0 (Pin)   <->  SPI_CS
GND              <->  GND


Important Notes:

Check the NanoPi M4 pinout for correct SPI1 pins

Use level shifters if voltage levels differ (3.3V vs 5V)

Enable SPI1 in the device tree first

The SPI slave mode in Linux may require kernel patches depending on your kernel version


